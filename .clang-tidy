---
Checks: bugprone-*,
  clang-analyzer-*,
  cert-*,
  readability-*,
  -clang-analyzer-security.insecureAPI.*
CheckOptions:
  # Functions & Variables (Standard C snake_case)
  readability-identifier-naming.FunctionCase: lower_case
  readability-identifier-naming.VariableCase: lower_case
  readability-identifier-naming.GlobalVariableCase: lower_case
  readability-identifier-naming.LocalVariableCase: lower_case
  readability-identifier-naming.StaticVariableCase: lower_case
  readability-identifier-naming.ParameterCase: lower_case

  # Struct/Union/Enum tags (Standard C snake_case)
  readability-identifier-naming.StructCase: lower_case
  readability-identifier-naming.UnionCase: lower_case
  readability-identifier-naming.EnumCase: lower_case

  # Members/fields (Standard C snake_case)
  readability-identifier-naming.MemberCase: lower_case

  # Macros & Constants (Standard C UPPER_CASE)
  readability-identifier-naming.EnumConstantCase: UPPER_CASE
  readability-identifier-naming.MacroDefinitionCase: UPPER_CASE
  readability-identifier-naming.ConstantCase: UPPER_CASE

  # Typedefs (Often suffixed with _t in C, e.g., uint32_t)
  readability-identifier-naming.TypeAliasCase: lower_case
  readability-identifier-naming.TypeAliasSuffix: '_t'
